        {
            "id": "section-2-1772292629770",
            "title": "Structure",
            "type": "formulas",
            "blocks": [
                {
                    "type": "code-block",
                    "label": "",
                    "content": "",
                    "items": [
                        "Subject + was/were + Verb-ing",
                        "She was studying London"
                    ],
                    "headers": [],
                    "rows": [],
                    "style": "",
                    "value": "",
                    "description": ""
                },
                {
                    "type": "code-block",
                    "label": "",
                    "content": "",
                    "items": [
                        "Subject + was/were + not + Verb-ing",
                        "She wasn't studying London"
                    ],
                    "headers": [],
                    "rows": [],
                    "style": "",
                    "value": "",
                    "description": ""
                },
                {
                    "type": "code-block",
                    "label": "",
                    "content": "",
                    "items": [
                        "Was/Were + Subject + Verb-ing?",
                        "Was she studying London?"
                    ],
                    "headers": [],
                    "rows": [],
                    "style": "",
                    "value": "",
                    "description": ""
                },
                {
                    "type": "info-box",
                    "label": "",
                    "content": "Use 'was' for I/He/She/It and 'were' for You/We/They",
                    "items": [],
                    "headers": [],
                    "rows": [],
