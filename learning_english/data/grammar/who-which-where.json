            "blocks": [
                {
                    "type": "paragraph",
                    "label": "DESCRIPTION",
                    "content": "Relative pronouns are used to connect a clause or phrase to a noun or pronoun. They help us give more information about a person, thing, or place without starting a new sentence.",
                    "items": [],
                    "headers": [],
                    "rows": [],
                    "style": "",
                    "value": "",
                    "description": ""
                },
                {
                    "type": "list",
                    "label": "EXAMPLE",
                    "content": "",
                    "items": [
                        "@_The man who lives next door is a doctor",
                        "@_This is the book that I bought yesterday",
                        "@_I visit the town where I was born"
                    ],
                    "headers": [],
                    "rows": [],
                    "style": "gold",
                    "value": "",
                    "description": ""
                }
            ]
