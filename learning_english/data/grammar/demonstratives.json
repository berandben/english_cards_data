            "blocks": [
                {
                    "type": "paragraph",
                    "label": "TIME CONTEXT",
                    "content": "We also use them to talk about time:",
                    "items": [],
                    "headers": [],
                    "rows": [],
                    "style": "",
                    "value": "",
                    "description": ""
                },
                {
                    "type": "list",
                    "label": "TIPS",
                    "content": "",
                    "items": [
                        "Use 'This' for current or future periods (This week, this summer)",
                        "Use 'That' for finished periods in the past (That day was great)",
                        "Introduce people: 'This is my brother, Mark'",
                        "On the phone: 'Hello, this is Sarah' (not 'I am Sarah')"
