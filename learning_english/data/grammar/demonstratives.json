            "blocks": [
                {
                    "type": "paragraph",
                    "label": "DESCRIPTION",
                    "content": "Demonstratives show where an object or person is in relation to the speaker. They can indicate physical distance or distance in time.",
                    "items": [],
                    "headers": [],
                    "rows": [],
                    "style": "",
                    "value": "",
                    "description": ""
                },
                {
                    "type": "list",
                    "label": "EXAMPLE",
                    "content": "",
                    "items": [
                        "@_This is my coffee (here)",
                        "@_That is my car over there (far)",
                        "@_These are my keys (in my hand)",
                        "@_Those are birds in the sky (far)"
                    ],
                    "headers": [],
                    "rows": [],
                    "style": "gold",
                    "value": "",
                    "description": ""
                }
            ]
        },
