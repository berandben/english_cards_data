                    "content": "",
                    "items": [
                        "@_In the morning/afternoon/evening BUT At night",
                        "@_On for days (Monday) and specific dates (May 5th)",
                        "@_At for exact times (7:30) and specific locations (at the door)",
                        "@_Transport: On for public (bus/train), In for private (car/taxi)"
