			"type": "info-grid",
			"blocks": [
				{
					"type": "paragraph",
					"label": "description",
					"content": "We use the Present Continuous to talk about actions happening now, temporary situations, or fixed future arrangements (plans that are already organized)",
					"items": [],
					"headers": [],
					"rows": [],
					"style": "",
					"value": "",
					"description": ""
				},
				{
					"type": "list",
					"label": "EXAMPLE",
					"content": "",
					"items": [
						"@_I am studying English right now",
						"@_She is staying at a hotel this week",
						"@_We are meeting friends tonight"
					],
					"headers": [],
					"rows": [],
					"style": "gold",
					"value": "",
					"description": ""
				}
			]
		},
